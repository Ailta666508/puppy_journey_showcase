# 复制为 `.env.local` 后按需填写（文件名须为 .env.local，前面有点）
#
# ========== 管线 Agent 1：剧本 LLM（OpenAI 兼容 Chat Completions）==========
# 与火山方舟接入方式一致时可填：BASE_URL=https://ark.cn-beijing.volces.com/api/v3 ，MODEL=推理接入点 ID（ep-...）
# 若排练室上传了参考图，需使用支持多模态的接入点。
# 与 Q 版一致时可用 ENDPOINT_ID 代替 MODEL（ep- 开头时会自动使用方舟 BASE_URL）
# 也可沿用下方 VITE_LLM_* 作为兼容别名（二选一即可）
PIPELINE_SCRIPT_LLM_API_KEY=
PIPELINE_SCRIPT_LLM_BASE_URL=
PIPELINE_SCRIPT_LLM_MODEL=
PIPELINE_SCRIPT_LLM_ENDPOINT_ID=
#
# ========== 兼容旧名（与 rehearsal_backend 一致，可与上一组二选一）==========
# VITE_LLM_API_KEY=
# VITE_LLM_API_URL=https://api.openai.com/v1
# VITE_LLM_MODEL=gpt-4o
#
# ========== 管线 Agent 2：火山方舟文生图（与 Q 版旅行页共用）==========
VOLCENGINE_Q_AVATAR_API_KEY=
VOLCENGINE_Q_AVATAR_ENDPOINT_ID=ep-xxxx
#
# ========== 管线 Agent 3：火山方舟图生视频（Seedance）==========
# 已填 PIPELINE_VIDEO_API_KEY（或 ARK / VOLC 回退）且能解析 BASE 时：一律走方舟图生视频（与 PIPELINE_VIDEO_PROVIDER 是否写 mock 无关）
# 无 Key 时：可设 PIPELINE_VIDEO_PROVIDER=mock 使用占位视频（约 4s）
# 有 Key 但仍要占位：PIPELINE_VIDEO_PROVIDER=mock 且 PIPELINE_VIDEO_FORCE_MOCK=1
# 方舟路径：POST /api/v3/contents/generations/tasks，GET /api/v3/contents/generations/tasks/{id}
# API Key 可与剧本/图片共用同一方舟 Key（Bearer）；也可用官方 curl 中的 ARK_API_KEY（二选一）
PIPELINE_VIDEO_PROVIDER=
PIPELINE_VIDEO_API_KEY=
# ARK_API_KEY=
PIPELINE_VIDEO_BASE_URL=
PIPELINE_VIDEO_MODEL=doubao-seedance-1-5-pro-251215
# ep- 接入点仅用于解析方舟 BASE_URL；请求体里的 model 会用上一行产品名，勿把 ep- 填进 PIPELINE_VIDEO_MODEL
PIPELINE_VIDEO_ENDPOINT_ID=
#
# 说明：变量在 Next 服务端 API 中读取，勿加 NEXT_PUBLIC_ 前缀以免泄露到浏览器。
# 换「模型名」还可改 src/lib/pipeline/config.ts 中的 SCRIPT_LLM_MODEL_DEFAULT 等常量。
#
# ========== Supabase（数据库 + Storage）==========
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# （service_role 仅服务端；变量名须为 SUPABASE_SERVICE_ROLE_KEY，勿写成 NEXT_PUBLIC_…）
# 情侣空间无需邮箱：在 Supabase 控制台 → Authentication → Providers → Anonymous 开启匿名登录。
# 数据库结构：在 Supabase → SQL Editor 按顺序执行（可复制文件全文粘贴）：
#   1) supabase/migrations/20250326120000_couples_profiles_and_couple_id.sql
#   2) supabase/migrations/20250327120000_couples_dog_slots_profiles_role.sql（黄白狗位 + profiles.role；可重复执行）
